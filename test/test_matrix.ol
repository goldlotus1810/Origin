use "lib/vec.ol"; let _tp = 0; let _tf = 0; if vec_dot([1,2,3], [4,5,6]) == 32 { _tp = _tp + 1; } else { _tf = _tf + 1; emit "FAIL: vec_dot"; }; let va = vec_add([1,2,3], [4,5,6]); if va[2] == 9 { _tp = _tp + 1; } else { _tf = _tf + 1; emit "FAIL: vec_add"; }; let vs = vec_sub([10,20], [1,2]); if vs[0] == 9 { _tp = _tp + 1; } else { _tf = _tf + 1; emit "FAIL: vec_sub"; }; let vk = vec_scale([1,2,3], 10); if vk[0] == 10 { _tp = _tp + 1; } else { _tf = _tf + 1; emit "FAIL: vec_scale"; }; let vc = vec_cross([1,0,0], [0,1,0]); if vc[2] == 1 { _tp = _tp + 1; } else { _tf = _tf + 1; emit "FAIL: vec_cross"; }; if _tf == 0 { emit "PASS"; } else { emit "FAIL"; };

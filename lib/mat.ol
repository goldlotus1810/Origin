fn mat_new(rows, cols) { let d = []; let i = 0; while i < rows * cols { push(d, 0); let i = i + 1; }; return { rows: rows, cols: cols, data: d }; }; fn mat_identity(n) { let m = mat_new(n, n); let i = 0; while i < n { set_at(m.data, i * n + i, 1); let i = i + 1; }; return m; }; fn mat_from_rows(rows) { let d = []; let r = 0; while r < len(rows) { let c = 0; while c < len(rows[r]) { push(d, rows[r][c]); let c = c + 1; }; let r = r + 1; }; return { rows: len(rows), cols: len(rows[0]), data: d }; }; fn mat_get(m, r, c) { return m.data[r * m.cols + c]; }; fn mat_set(m, r, c, val) { set_at(m.data, r * m.cols + c, val); return m; }; fn mat_add(a, b) { let d = []; let i = 0; while i < len(a.data) { push(d, a.data[i] + b.data[i]); let i = i + 1; }; return { rows: a.rows, cols: a.cols, data: d }; }; fn mat_transpose(m) { let d = mat_new(m.cols, m.rows); let r = 0; while r < m.rows { let c = 0; while c < m.cols { set_at(d.data, c * m.rows + r, m.data[r * m.cols + c]); let c = c + 1; }; let r = r + 1; }; return d; }; fn mat_mul(a, b) { let res = mat_new(a.rows, b.cols); let r = 0; while r < a.rows { let c = 0; while c < b.cols { let s = 0; let k = 0; while k < a.cols { let s = s + a.data[r * a.cols + k] * b.data[k * b.cols + c]; let k = k + 1; }; set_at(res.data, r * b.cols + c, s); let c = c + 1; }; let r = r + 1; }; return res; }; fn mat_det(m) { if m.rows == 1 { return m.data[0]; }; if m.rows == 2 { return m.data[0]*m.data[3] - m.data[1]*m.data[2]; }; return 0; };

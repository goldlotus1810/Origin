fn vec_dot(a, b) { let s = 0; let i = 0; while i < len(a) { let s = s + a[i] * b[i]; let i = i + 1; }; return s; }; fn vec_norm(v) { return __sqrt(vec_dot(v, v)); }; fn vec_add(a, b) { let r = []; let i = 0; while i < len(a) { push(r, a[i] + b[i]); let i = i + 1; }; return r; }; fn vec_sub(a, b) { let r = []; let i = 0; while i < len(a) { push(r, a[i] - b[i]); let i = i + 1; }; return r; }; fn vec_scale(v, s) { let r = []; let i = 0; while i < len(v) { push(r, v[i] * s); let i = i + 1; }; return r; }; fn vec_cross(a, b) { return [a[1]*b[2] - a[2]*b[1], a[2]*b[0] - a[0]*b[2], a[0]*b[1] - a[1]*b[0]]; }; fn mat_new(rows, cols) { let d = []; let i = 0; while i < rows * cols { push(d, 0); let i = i + 1; }; return { rows: rows, cols: cols, data: d }; }; fn mat_identity(n) { let m = mat_new(n, n); let i = 0; while i < n { set_at(m.data, i * n + i, 1); let i = i + 1; }; return m; }; fn mat_from_rows(rows) { let d = []; let r = 0; while r < len(rows) { let c = 0; while c < len(rows[r]) { push(d, rows[r][c]); let c = c + 1; }; let r = r + 1; }; return { rows: len(rows), cols: len(rows[0]), data: d }; }; fn mat_get(m, r, c) { return m.data[r * m.cols + c]; }; fn mat_set(m, r, c, val) { set_at(m.data, r * m.cols + c, val); return m; }; fn mat_add(a, b) { let d = []; let i = 0; while i < len(a.data) { push(d, a.data[i] + b.data[i]); let i = i + 1; }; return { rows: a.rows, cols: a.cols, data: d }; }; fn mat_transpose(m) { let d = mat_new(m.cols, m.rows); let r = 0; while r < m.rows { let c = 0; while c < m.cols { set_at(d.data, c * m.rows + r, m.data[r * m.cols + c]); let c = c + 1; }; let r = r + 1; }; return d; }; fn mat_mul(a, b) { let res = mat_new(a.rows, b.cols); let r = 0; while r < a.rows { let c = 0; while c < b.cols { let s = 0; let k = 0; while k < a.cols { let s = s + a.data[r * a.cols + k] * b.data[k * b.cols + c]; let k = k + 1; }; set_at(res.data, r * b.cols + c, s); let c = c + 1; }; let r = r + 1; }; return res; }; fn mat_det(m) { if m.rows == 1 { return m.data[0]; }; if m.rows == 2 { return m.data[0] * m.data[3] - m.data[1] * m.data[2]; }; if m.rows == 3 { let a = m.data[0]; let b = m.data[1]; let c = m.data[2]; let d = m.data[3]; let e = m.data[4]; let f = m.data[5]; let g = m.data[6]; let h = m.data[7]; let ii = m.data[8]; return a*(e*ii - f*h) - b*(d*ii - f*g) + c*(d*h - e*g); }; return 0; };

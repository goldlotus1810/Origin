fn vec_dot(a, b) { let s = 0; let i = 0; while i < len(a) { let v1 = a[i]; let v2 = b[i]; let s = s + v1 * v2; let i = i + 1; }; return s; }; fn vec_norm(v) { return __isqrt(vec_dot(v, v)); }; fn vec_add(a, b) { let r = []; let i = 0; while i < len(a) { let v1 = a[i]; let v2 = b[i]; push(r, v1 + v2); let i = i + 1; }; return r; }; fn vec_sub(a, b) { let r = []; let i = 0; while i < len(a) { let v1 = a[i]; let v2 = b[i]; push(r, v1 - v2); let i = i + 1; }; return r; }; fn vec_scale(v, k) { let r = []; let i = 0; while i < len(v) { let val = v[i]; push(r, val * k); let i = i + 1; }; return r; }; fn vec_cross(a, b) { let a0 = a[0]; let a1 = a[1]; let a2 = a[2]; let b0 = b[0]; let b1 = b[1]; let b2 = b[2]; let r = []; push(r, a1*b2 - a2*b1); push(r, a2*b0 - a0*b2); push(r, a0*b1 - a1*b0); return r; };

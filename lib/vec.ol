fn vec_dot(a, b) { let s = 0; let i = 0; while i < len(a) { let s = s + a[i] * b[i]; let i = i + 1; }; return s; }; fn vec_norm(v) { return __sqrt(vec_dot(v, v)); }; fn vec_add(a, b) { let r = []; let i = 0; while i < len(a) { push(r, a[i] + b[i]); let i = i + 1; }; return r; }; fn vec_sub(a, b) { let r = []; let i = 0; while i < len(a) { push(r, a[i] - b[i]); let i = i + 1; }; return r; }; fn vec_scale(v, s) { let r = []; let i = 0; while i < len(v) { push(r, v[i] * s); let i = i + 1; }; return r; }; fn vec_cross(a, b) { return [a[1]*b[2] - a[2]*b[1], a[2]*b[0] - a[0]*b[2], a[0]*b[1] - a[1]*b[0]]; };
